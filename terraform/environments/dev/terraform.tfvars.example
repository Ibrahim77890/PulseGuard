project_id                    = "my-gcp-project-id"
region                        = "us-central1"
cluster_name                  = "pulseguard-dev"
network                       = "pulseguard-vpc"
subnetwork                    = "pulseguard-gke-subnet"
cluster_secondary_range_name  = "gke-pods"
services_secondary_range_name = "gke-services"
environment                   = "dev"
owner                         = "platform"
observability_namespace       = "observability"
grafana_admin_password        = "replace-with-a-strong-password"
grafana_storage_size          = "10Gi"
prometheus_storage_size       = "30Gi"
loki_storage_size             = "30Gi"
tempo_storage_size            = "20Gi"
slo_services                  = ["frontend", "backend", "data"]
enable_google_monitoring_slos = false
artifact_registry_repository_id = "pulseguard-workloads"
binary_authorization_enforcement_mode = "DRYRUN_AUDIT_LOG_ONLY"
enable_falco                    = true
enable_scc_notification_config  = false
enable_chaos_mesh               = true
enable_gatekeeper               = true
enable_opencost                 = true
create_billing_export_dataset   = true
enable_billing_budget           = false
# billing_account_id            = "000000-000000-000000"
aiops_service_image             = "us-central1-docker.pkg.dev/my-gcp-project-id/pulseguard-workloads/aiops-assistant:latest"
aiops_enable_redis_memory       = true
aiops_otel_exporter_otlp_endpoint = "http://otel-collector.observability.svc.cluster.local:4318/v1/traces"
# openrouter_api_key_secret_value = "replace-me"
